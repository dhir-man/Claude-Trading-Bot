# ─── Ollama (local) ───────────────────────────────────────────────────────────
OLLAMA_BASE_URL=http://localhost:11434

# ─── Qwen2.5-Coder 7B (via Ollama) ───────────────────────────────────────────
QWEN_MODEL=qwen2.5-coder:7b-instruct-q4_K_M
# QWEN_MODEL=qwen2.5-coder:14b-instruct-q4_K_M
# QWEN_MODEL=qwen2.5-coder:32b-instruct-q4_K_M

# ─── DeepSeek-Coder 6.7B (via Ollama or API) ─────────────────────────────────
DEEPSEEK_MODEL=deepseek-coder:6.7b-instruct-q4_K_M
DEEPSEEK_API_KEY=your_deepseek_api_key_here
DEEPSEEK_API_BASE_URL=https://api.deepseek.com/v1

# ─── GLM-4 (Zhipu AI) ────────────────────────────────────────────────────────
GLM_API_KEY=your_zhipu_api_key_here
GLM_API_BASE_URL=https://open.bigmodel.cn/api/paas/v4

# ─── Claude (Anthropic) ───────────────────────────────────────────────────────
ANTHROPIC_API_KEY=your_anthropic_api_key_here
CLAUDE_MODEL=claude-sonnet-4-6

# ─── OpenAI ───────────────────────────────────────────────────────────────────
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4o
OPENAI_API_BASE_URL=https://api.openai.com/v1

# ─── LiteLLM proxy (points to your local LiteLLM server) ─────────────────────
# Start with: litellm --model ollama/qwen2.5-coder:7b-instruct-q4_K_M
LITELLM_BASE_URL=http://localhost:4000
LITELLM_API_KEY=your_litellm_api_key_here
LITELLM_MODEL=ollama/qwen2.5-coder:7b-instruct-q4_K_M

# ─── LangChain driver ────────────────────────────────────────────────────────
# Set to "ollama" or "anthropic" or "openai"
LANGCHAIN_DRIVER=anthropic
LANGCHAIN_MODEL=claude-sonnet-4-6

# ─── Evaluation settings ──────────────────────────────────────────────────────
EVAL_TIMEOUT_MS=60000
EVAL_MAX_RETRIES=2
LOG_LEVEL=info

# ─── Output directory for LLM response files ──────────────────────────────────
OUTPUT_DIR=./outputs
