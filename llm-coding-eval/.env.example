# ─── Ollama (local) ───────────────────────────────────────────────────────────
# Default Ollama endpoint — change if running on a remote server
OLLAMA_BASE_URL=http://localhost:11434

# ─── Qwen3-Coder 32B (via Ollama) ────────────────────────────────────────────
QWEN32B_MODEL=qwen3-coder:32b-instruct-q4_K_M
# Alternatively pull the full FP16 on a beefy server:
# QWEN32B_MODEL=qwen3-coder:32b-instruct-fp16

# ─── DeepSeek-Coder V3 (via Ollama) ──────────────────────────────────────────
DEEPSEEK_MODEL=deepseek-coder-v3:latest
# Official DeepSeek API (free tier, 60 RPM, 1M tokens/month free)
DEEPSEEK_API_KEY=your_deepseek_api_key_here
DEEPSEEK_API_BASE_URL=https://api.deepseek.com/v1

# ─── GLM-5 / GLM-4 (Zhipu AI) ────────────────────────────────────────────────
# Free tier: 6M tokens/month, ~$0.0014/1K tokens after
GLM_API_KEY=your_zhipu_api_key_here
GLM_API_BASE_URL=https://open.bigmodel.cn/api/paas/v4

# ─── Evaluation settings ──────────────────────────────────────────────────────
EVAL_TIMEOUT_MS=60000
EVAL_MAX_RETRIES=2
LOG_LEVEL=info
