{
  "name": "llm-coding-eval",
  "version": "1.0.0",
  "description": "Evaluation harness for free-for-commercial-use LLMs: Qwen3-Coder-32B, DeepSeek-Coder-V3, GLM-5",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc && node -e \"require('fs').copyFileSync('src/leetcode/eval-worker.js','dist/leetcode/eval-worker.js')\"",
    "start": "node dist/index.js",
    "test": "jest --runInBand --forceExit",
    "test:qwen7b": "cross-env MODEL=qwen7b jest --runInBand --forceExit",
    "test:deepseek": "cross-env MODEL=deepseek jest --runInBand --forceExit",
    "test:glm": "cross-env MODEL=glm jest --runInBand --forceExit",
    "test:all": "node dist/run-all.js",
    "eval:claude": "ts-node src/eval-runner.ts --driver claude --all",
    "eval:openai": "ts-node src/eval-runner.ts --driver openai --all",
    "eval:deepseek": "ts-node src/eval-runner.ts --driver deepseek --all",
    "eval:ollama-qwen7b": "ts-node src/eval-runner.ts --driver ollama-qwen7b --all",
    "eval:ollama-qwen14b": "ts-node src/eval-runner.ts --driver ollama-qwen14b --all",
    "eval:ollama-deepseek": "ts-node src/eval-runner.ts --driver ollama-deepseek --all",
    "eval:litellm": "ts-node src/eval-runner.ts --driver litellm --all",
    "eval:langchain-anthropic": "ts-node src/eval-runner.ts --driver langchain-anthropic --all",
    "eval:langchain-openai": "ts-node src/eval-runner.ts --driver langchain-openai --all",
    "eval:langchain-ollama": "ts-node src/eval-runner.ts --driver langchain-ollama --all",
    "eval:interactive": "ts-node src/eval-runner.ts",
    "eval": "ts-node src/run-eval.ts",
    "server:start": "node dist/api-server.js",
    "scheduler:try": "node dist/try-scheduler.js",
    "setup:ollama": "node scripts/setup-ollama.js",
    "deck": "node scripts/build-deck.js",
    "dev": "ts-node src/index.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.104.1",
    "@langchain/anthropic": "^1.4.1",
    "@langchain/openai": "^1.4.7",
    "@types/uuid": "^10.0.0",
    "axios": "^1.7.2",
    "chalk": "^4.1.2",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "langchain": "^1.4.5",
    "node-cron": "^3.0.3",
    "openai": "^6.43.0",
    "ora": "^5.4.1",
    "pptxgenjs": "^4.0.1",
    "table": "^6.8.1",
    "uuid": "^14.0.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.12",
    "@types/node": "^20.14.2",
    "@types/node-cron": "^3.0.11",
    "cross-env": "^10.1.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.4",
    "typescript": "^5.4.5"
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node",
    "testTimeout": 120000,
    "testMatch": [
      "**/tests/**/*.test.ts"
    ],
    "globals": {
      "ts-jest": {
        "tsconfig": "tsconfig.json"
      }
    }
  }
}
